# Згенерувати ключ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# True під час розробки, False у продакшені
DEBUG=True

# PostgreSQL
DB_NAME=study_platform
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# CORS — comma-separated list of allowed origins for the Next.js frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
BACKEND_URL=http://localhost:8000