# Згенерувати ключ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# True під час розробки, False у продакшені
DEBUG=True

# При деплої в ALLOWED_HOSTS буде власний домен
# ALLOWED_HOSTS=myapi.com,www.myapi.com

# PostgreSQL — DB_HOST=db для DevContainer, localhost для локальної розробки без Docker
DB_NAME=study_platform
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=db
DB_PORT=5432



# URL фронтенду (Next.js) — використовується у листах і як default для CORS
FRONTEND_URL=http://localhost:3000

# CORS — за замовчуванням дорівнює FRONTEND_URL; задавати тільки для додаткових origins
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Email
# DEBUG=True: листи друкуються в термінал, ці змінні не потрібні
# DEBUG=False: потрібен реальний SMTP
# Gmail: Account → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
